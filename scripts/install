#!/bin/bash

#=================================================
# COMMON_SCRIPT
#=================================================

# Load YunoHost helper
source /usr/share/yunohost/helpers

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Setting up source files..."

# This will download the correct zip based on arch and extract it to $install_dir
# It also handles moving files from the 'release' subdir if specified in manifest
ynh_setup_source --dest_dir="$install_dir"

# Debug: check extracted files
ynh_print_info "Checking extracted files in $install_dir..."
ls -la "$install_dir"

# Set binary as executable
chmod +x "$install_dir/animarr"

#=================================================
# APP INITIAL CONFIGURATION
#=================================================
ynh_script_progression "Adding $app's configuration files..."

# Define data directory
data_path="/var/lib/$app"
mkdir -p "$data_path"
chown -R "$app:$app" "$data_path"

# Link data directory to the app folder
ln -s "$data_path" "$install_dir/data"

# Create .env file from example and replace placeholder
if [ -f "$install_dir/.env.example" ]; then
    cp "$install_dir/.env.example" "$install_dir/.env"
else
    # Fallback if .env.example is missing (manual creation)
    cat <<EOF > "$install_dir/.env"
# Animarr Configuration
PORT=__PORT__
ADMIN_USER=admin
ADMIN_PASSWORD=
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=
EOF
fi

sed -i "s/__PORT__/$port/g" "$install_dir/.env"

# Final permissions
chown -R "$app:$app" "$install_dir"

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations related to $app..."

# Add Nginx and Systemd configs
ynh_add_nginx_config
ynh_add_systemd_config

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemd_action --service="$app" --action="start"
ynh_systemd_action --service="$app" --action="enable"

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Installation of $app completed"
